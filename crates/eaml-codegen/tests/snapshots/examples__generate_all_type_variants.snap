# Generated by eamlc from types.eaml

from pydantic import BaseModel, Field
from typing import List, Literal, Optional
from eaml_runtime import execute_prompt

# --- Schemas ---

class Primitives(BaseModel):
    label: str
    score: float
    count: int
    active: bool
    empty: None

class BoundedTypes(BaseModel):
    probability: float = Field(ge=0.0, le=1.0)
    rating: float = Field(ge=0.0, le=5.0)
    short_text: str = Field(max_length=200)
    description: str = Field(min_length=1, max_length=1000)
    age: int = Field(ge=0)
    percentage: int = Field(ge=0, le=100)

class CompositeTypes(BaseModel):
    required_name: str
    optional_name: Optional[str] = None
    tag_list: List[int]
    optional_tags: Optional[List[str]] = None
    nullable_items: List[Optional[str]]
    fully_optional: Optional[List[Optional[str]]] = None

class UnionTypes(BaseModel):
    binary_choice: Literal["yes", "no"]
    direction: Literal["north", "south", "east", "west"]
    priority: Literal["low", "medium", "high", "critical"]

class Address(BaseModel):
    street: str
    city: str
    zip_code: str = Field(min_length=1, max_length=20)

class Person(BaseModel):
    full_name: str
    email: Optional[str] = None
    address: Address
    previous_addresses: Optional[List[Address]] = None

# --- Models ---

CLAUDE_CONFIG = {
    "provider": "anthropic",
    "model_id": "anthropic/claude-3-5-sonnet-20241022",
    "capabilities": ["json_mode"],
}

# --- Prompts and Tools ---

async def describe_person(name: str, *, model: dict) -> Person:
    messages = [
        {"role": "user", "content": f"Create a profile for a person named {name}."},
    ]
    return await eaml_runtime.execute_prompt(
        model=model,
        messages=messages,
        return_type=Person,
    )

async def classify_priority(task: str, *, model: dict) -> Literal["low", "medium", "high", "critical"]:
    messages = [
        {"role": "user", "content": f"Classify the priority of this task: {task}"},
    ]
    return await eaml_runtime.execute_prompt(
        model=model,
        messages=messages,
        return_type=Literal["low", "medium", "high", "critical"],
    )

async def summarize(text: str, *, model: dict) -> str:
    messages = [
        {"role": "user", "content": f"Summarize the following in one sentence: {text}"},
    ]
    return await eaml_runtime.execute_prompt(
        model=model,
        messages=messages,
        return_type=str,
    )
