# Generated by eamlc from minimal.eaml

from pydantic import BaseModel
from eaml_runtime import execute_prompt

# --- Schemas ---

class Greeting(BaseModel):
    message: str
    word_count: int

# --- Models ---

HAIKU_CONFIG = {
    "provider": "anthropic",
    "model_id": "anthropic/claude-3-haiku-20240307",
    "capabilities": [],
}

# --- Prompts and Tools ---

async def greet(name: str, *, model: dict) -> Greeting:
    messages = [
        {"role": "user", "content": f"Say hello to {name} and count the words in your greeting."},
    ]
    return await execute_prompt(
        model=model,
        messages=messages,
        return_type=Greeting,
    )
